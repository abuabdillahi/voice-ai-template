.venv
**/.venv

dist
**/dist
build
**/build

.git
.gitignore
.github

.env
.env.local
**/.env
**/.env.local

.uv-cache
.turbo
**/.turbo

__pycache__
**/__pycache__
*.pyc
*.pyo

.scratch
.worktrees

# IDE / OS
.DS_Store
.vscode
.idea
