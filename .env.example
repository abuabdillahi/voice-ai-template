# Copy to `.env` and fill in real values. The dev and prod docker compose
# stacks both load this file via `env_file: .env`.

# --- Supabase (backend) ---
# Project URL, anon/public key, and the JWT signing secret. The first two
# are also exposed to the browser via the `VITE_*` mirrors below; the JWT
# secret stays server-side and is what `core.auth.verify_token` uses to
# validate access tokens issued by Supabase.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# --- Supabase (browser-exposed mirrors) ---
# Vite only ships variables prefixed with VITE_ to the client bundle.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- HTTP / CORS ---
# Comma-separated list of additional origins allowed by the API. The
# Vite dev server origin is included unconditionally.
CORS_ORIGINS=http://localhost:5173

# Base URL of the FastAPI backend, as seen by the browser.
VITE_API_URL=http://localhost:8000

# --- Observability ---
LOG_LEVEL=INFO
ENVIRONMENT=development

# --- LiveKit ---
# In development, point at your LiveKit Cloud project (free tier is
# sufficient): wss://<project>.livekit.cloud. In production with the
# self-hosted compose stack, this becomes ws://livekit-server:7880 (or
# wss://<your-domain>:7880 behind a TLS-terminating reverse proxy).
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# --- OpenAI ---
# Used by the default realtime model in `core.realtime`. Provide a key
# with access to the realtime model family (e.g. `gpt-realtime`).
OPENAI_API_KEY=sk-your-openai-key
