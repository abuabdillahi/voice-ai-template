# Copy to `.env` and fill in real values. The dev and prod docker compose
# stacks both load this file via `env_file: .env`.

# --- Supabase ---
# Project URL (e.g. https://abcd1234.supabase.co) and anon/public key.
# Used by the API for auth verification and by the web SPA at runtime.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# --- LiveKit (added in issue 05) ---
# LIVEKIT_URL=ws://livekit-server:7880
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=

# --- OpenAI (added in issue 05) ---
# OPENAI_API_KEY=
