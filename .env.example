# Copy to `.env` and fill in real values. The dev and prod docker compose
# stacks both load this file via `env_file: .env`.

# --- Supabase (backend) ---
# Project URL and the publishable (formerly "anon") API key. JWT
# verification uses the project's JWKS endpoint at
# {SUPABASE_URL}/auth/v1/.well-known/jwks.json — no secret is needed.
# Self-hosted deployments at non-standard paths can override the JWKS
# URL via SUPABASE_JWKS_URL.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
# SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

# --- Supabase (browser-exposed mirrors) ---
# Vite only ships variables prefixed with VITE_ to the client bundle.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# --- HTTP / CORS ---
# Comma-separated list of additional origins allowed by the API. The
# Vite dev server origin is included unconditionally.
CORS_ORIGINS=http://localhost:5173,http://localhost

# Base URL of the FastAPI backend, as seen by the browser.
VITE_API_URL=http://localhost:8000

# --- Observability ---
LOG_LEVEL=INFO
ENVIRONMENT=development

# --- LiveKit ---
# Both dev and prod point at a hosted LiveKit Cloud project — the free
# tier is sufficient for development. Use a separate Cloud project (or
# at least a separate API key/secret pair) for production deployments.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# --- OpenAI ---
# Used by the default realtime model in `core.realtime`. Provide a key
# with access to the realtime model family (e.g. `gpt-realtime`).
OPENAI_API_KEY=sk-your-openai-key

# --- OpenStreetMap (clinician finder) ---
# Operator contact email embedded in the User-Agent on every Nominatim
# (geocoding) and Overpass (POI search) request, per the OSMF usage
# policy. When unset, the `find_clinician` tool is unregistered and
# the offer language is dropped from the system prompt — the feature
# is silently disabled rather than surfacing a runtime "maps service
# unavailable" mid-conversation. Use a real address you'd be reachable
# on; OSMF operators contact it if our traffic against the public
# instances misbehaves.
OSM_CONTACT_EMAIL=you@example.com
# Optional overrides; defaults are the public instances:
# NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# OVERPASS_BASE_URL=https://overpass-api.de/api/interpreter

# --- mem0 (episodic memory) ---
# Postgres connection URL for mem0's pgvector backend.
#
# Use the SESSION pooler (port 5432), NOT the Transaction pooler (6543).
# Transaction pooler reuses backend connections across transactions, which
# breaks psycopg's auto-prepared statements with:
#     DuplicatePreparedStatement: prepared statement "_pg3_0" already exists
# Session pooler pins a backend per client connection → prepared statements
# work and mem0's pgvector backend is happy.
#
# Get from: Supabase Dashboard → Project Settings → Database
#                              → Connection string → Session pooler.
# Avoid the direct `db.<ref>.supabase.co` host — it is IPv6-only and
# Docker Desktop's default network cannot reach it.
# Format: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
MEM0_POSTGRES_URL=postgresql://postgres.your-ref:your-db-password@aws-0-region.pooler.supabase.com:5432/postgres # pragma: allowlist secret
# Optional overrides; defaults match supabase/migrations/0003_mem0_memories.sql:
# MEM0_COLLECTION=mem0_memories
# MEM0_EMBEDDING_DIMS=1536
